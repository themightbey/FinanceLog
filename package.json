{
  "name": "financelog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd vite && npm install && npm run build",
    "deploy": "npm run build && npx wrangler deploy",
    "deploy:only": "npx wrangler deploy",
    "dev:worker": "npx wrangler dev",
    "db:init": "npx wrangler d1 execute financelog --file=./worker/schema.sql",
    "db:init:remote": "npx wrangler d1 execute financelog --remote --file=./worker/schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.81.0"
  }
}
